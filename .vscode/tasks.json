{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build and run C",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-Command",
        "gcc ${file} -o ${fileBasenameNoExtension}.exe; ./${fileBasenameNoExtension}.exe"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
